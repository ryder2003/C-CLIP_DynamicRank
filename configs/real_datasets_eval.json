{
  "checkpoint_path": "checkpoints/real_datasets/model_final.pt",
  "config_path": "configs/real_datasets_config.yaml",
  "output_path": "results/real_datasets_eval.json",

  "note": "These are classification datasets. Use eval_zero_shot.py for accuracy metrics. Retrieval metrics are only meaningful for datasets with unique per-image captions (Flickr30k, MSCOCO).",

  "zero_shot_eval_command": "python scripts/eval_zero_shot.py --checkpoint checkpoints/real_datasets/model_final.pt --config configs/real_datasets_config.yaml",

  "per_task_eval_commands": {
    "after_task_0": "python scripts/eval_zero_shot.py --checkpoint checkpoints/real_datasets/model_after_task_0.pt --config configs/real_datasets_config.yaml --output results/task0_accuracy.json",
    "after_task_1": "python scripts/eval_zero_shot.py --checkpoint checkpoints/real_datasets/model_after_task_1.pt --config configs/real_datasets_config.yaml --output results/task1_accuracy.json",
    "final": "python scripts/eval_zero_shot.py --checkpoint checkpoints/real_datasets/model_final.pt --config configs/real_datasets_config.yaml --output results/final_accuracy.json"
  },

  "latest_results_summary": {
    "pretrained_baseline": {"flowers102": 69.63, "oxford_pets": 88.72, "simpsons": 61.58},
    "after_task_0": {"flowers102": 99.43, "oxford_pets": 85.47, "simpsons": 51.16},
    "after_task_1": {"flowers102": 99.19, "oxford_pets": 95.85, "simpsons": 53.27},
    "final": {"flowers102": 84.69, "oxford_pets": 91.88, "simpsons": 98.12},
    "avg_final_accuracy": 91.56,
    "backward_transfer": -9.36
  },

  "eval_datasets": [
    {
      "name": "flowers102",
      "type": "zero_shot_classification",
      "val_csv": "data/flowers102/val.csv",
      "image_dir": "datasets/102flowers/jpg",
      "n_classes": 102
    },
    {
      "name": "oxford_pets",
      "type": "zero_shot_classification",
      "val_csv": "data/oxford_pets/val.csv",
      "image_dir": "datasets/Oxford_IIITPets/images",
      "n_classes": 37
    },
    {
      "name": "simpsons",
      "type": "zero_shot_classification",
      "val_csv": "data/simpsons/val.csv",
      "image_dir": "datasets/simpsons_archive/simpsons_dataset",
      "n_classes": 43
    }
  ]
}
